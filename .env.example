# Runtime environment
ENVIRONMENT=development
APP_NAME=shl-assessment-recommendation-agent
APP_VERSION=0.1.0
DEBUG=false

# Server settings (reserved for API module)
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Logging configuration
LOG_DIR=logs
LOG_FILE=app.log

# LLM provider settings (reserved for future agent modules)
LLM_PROVIDER=openai
LLM_MODEL_CONVERSATION_STATE=gpt-4o-mini
LLM_MODEL_RESPONSE=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
OPENAI_API_KEY=replace-with-api-key

# Catalog settings
CATALOG_PATH=catalog/validated_catalog.json

# Retrieval resources (reserved for future retrieval modules)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=64
BM25_INDEX_PATH=retrieval/indexes/bm25.pkl
FAISS_INDEX_PATH=retrieval/indexes/faiss.index
TOP_K_BM25=20
TOP_K_EMBEDDING=20
RRF_K=60

# Confidence and routing controls (reserved for future routing modules)
MIN_RETRIEVAL_CONFIDENCE=0.35
MIN_RECOMMENDATION_COUNT=1
MAX_RECOMMENDATION_COUNT=8

# Evaluation and offline runs
EVAL_DATA_PATH=eval/data
EVAL_OUTPUT_PATH=eval/output